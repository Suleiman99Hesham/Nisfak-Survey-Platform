          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/dependencies/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "dependencies", ""] }
          }
        },
        {
          "name": "Create dependency: options_filter (department -> role_level)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_field\": \"{{fieldDeptId}}\",\n  \"target_field\": \"{{fieldRoleId}}\",\n  \"dependency_type\": \"options_filter\",\n  \"config\": {\n    \"mapping\": {\n      \"eng\":   [\"eng_junior\", \"eng_senior\"],\n      \"sales\": [\"sales_ae\", \"sales_mgr\"]\n    },\n    \"default\": []\n  }\n}"
            },
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/dependencies/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "dependencies", ""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) pm.collectionVariables.set('dependencyId', body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create dependency: required_if (employed -> role_level required)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_field\": \"{{fieldEmpId}}\",\n  \"target_field\": \"{{fieldRoleId}}\",\n  \"dependency_type\": \"required_if\",\n  \"config\": {\"condition\": {\"operator\": \"eq\", \"value\": \"employed\"}}\n}"
            },
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/dependencies/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "dependencies", ""] }
          }
        },
        {
          "name": "Create dependency: visibility (example)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_field\": \"{{fieldEmpId}}\",\n  \"target_field\": \"{{fieldRoleId}}\",\n  \"dependency_type\": \"visibility\",\n  \"config\": {\"condition\": {\"operator\": \"eq\", \"value\": \"employed\"}}\n}"
            },
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/dependencies/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "dependencies", ""] }
          }
        },
        {
          "name": "Dependency detail",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/dependencies/{{dependencyId}}/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "dependencies", "{{dependencyId}}", ""] }
          }
        },
        {
          "name": "Update dependency",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"config\": {\"mapping\": {\"eng\": [\"eng_senior\"], \"sales\": [\"sales_mgr\"]}, \"default\": []}\n}" },
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/dependencies/{{dependencyId}}/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "dependencies", "{{dependencyId}}", ""] }
          }
        },
        {
          "name": "Delete dependency",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/dependencies/{{dependencyId}}/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "dependencies", "{{dependencyId}}", ""] }
          }
        }
      ]
