    {
      "name": "Respondent (Public)",
      "item": [
        {
          "name": "Get published survey",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/public/surveys/{{surveyId}}/", "host": ["{{baseUrl}}"], "path": ["public", "surveys", "{{surveyId}}", ""] }
          }
        },
        {
          "name": "Start submission",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/public/surveys/{{surveyId}}/start/", "host": ["{{baseUrl}}"], "path": ["public", "surveys", "{{surveyId}}", "start", ""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) pm.collectionVariables.set('submissionId', body.id);",
                  "if (body.resume_token) pm.collectionVariables.set('resumeToken', body.resume_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Save answers (Case A: employed, 5 yrs, eng/senior, reference)",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Resume-Token", "value": "{{resumeToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\"field_id\": \"{{fieldEmpId}}\",   \"value\": \"employed\"},\n  {\"field_id\": \"{{fieldYearsId}}\", \"value\": 5},\n  {\"field_id\": \"{{fieldDeptId}}\",  \"value\": \"eng\"},\n  {\"field_id\": \"{{fieldRoleId}}\",  \"value\": \"eng_senior\"},\n  {\"field_id\": \"{{fieldRefId}}\",   \"value\": \"Jane Doe\"}\n]"
            },
            "url": { "raw": "{{baseUrl}}/public/responses/{{submissionId}}/answers/", "host": ["{{baseUrl}}"], "path": ["public", "responses", "{{submissionId}}", "answers", ""] }
          }
        },
        {
          "name": "Save draft (explicit)",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "X-Resume-Token", "value": "{{resumeToken}}" }],
            "url": { "raw": "{{baseUrl}}/public/responses/{{submissionId}}/save-draft/", "host": ["{{baseUrl}}"], "path": ["public", "responses", "{{submissionId}}", "save-draft", ""] }
          }
        },
        {
          "name": "Current submission state",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "header": [{ "key": "X-Resume-Token", "value": "{{resumeToken}}" }],
            "url": { "raw": "{{baseUrl}}/public/responses/{{submissionId}}/current/", "host": ["{{baseUrl}}"], "path": ["public", "responses", "{{submissionId}}", "current", ""] }
          }
        },
        {
          "name": "Submit response",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "X-Resume-Token", "value": "{{resumeToken}}" }],
            "url": { "raw": "{{baseUrl}}/public/responses/{{submissionId}}/submit/", "host": ["{{baseUrl}}"], "path": ["public", "responses", "{{submissionId}}", "submit", ""] }
          }
        },
        {
          "name": "Resume by token",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/public/responses/resume/{{resumeToken}}/", "host": ["{{baseUrl}}"], "path": ["public", "responses", "resume", "{{resumeToken}}", ""] }
          }
        },
        {
          "name": "Save answers (Case B: invalid option — sales_mgr under eng)",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
