    {
      "name": "Visibility Rules",
      "item": [
        {
          "name": "List rules",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/rules/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "rules", ""] }
          }
        },
        {
          "name": "Create rule (AND: employed AND years >= 3 shows References section)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target_type\": \"section\",\n  \"target_id\": \"{{sectionRefsId}}\",\n  \"logical_operator\": \"AND\",\n  \"conditions\": [\n    {\"source_field\": \"{{fieldEmpId}}\",   \"operator\": \"eq\",  \"expected_value\": \"employed\"},\n    {\"source_field\": \"{{fieldYearsId}}\", \"operator\": \"gte\", \"expected_value\": 3}\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/rules/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "rules", ""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) pm.collectionVariables.set('ruleId', body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Rule detail",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/rules/{{ruleId}}/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "rules", "{{ruleId}}", ""] }
          }
        },
        {
          "name": "Update rule (switch to OR)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"logical_operator\": \"OR\"\n}" },
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/rules/{{ruleId}}/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "rules", "{{ruleId}}", ""] }
          }
        },
        {
          "name": "Delete rule",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/rules/{{ruleId}}/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "rules", "{{ruleId}}", ""] }
          }
        }
      ]
    },
    {
      "name": "Field Dependencies",
