{
  "info": {
    "name": "Nisfak Survey Platform",
    "description": "Postman collection for the Advanced Dynamic Survey Platform API. Requests are ordered so you can run them top-to-bottom — test scripts auto-capture IDs (survey, sections, fields, submission, resume_token) into collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "nisfak-survey-platform-v1"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000/api/v1" },
    { "key": "adminUsername", "value": "admin" },
    { "key": "adminPassword", "value": "admin" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "surveyId", "value": "" },
    { "key": "sectionAboutId", "value": "" },
    { "key": "sectionRoleId", "value": "" },
    { "key": "sectionRefsId", "value": "" },
    { "key": "fieldEmpId", "value": "" },
    { "key": "fieldYearsId", "value": "" },
    { "key": "fieldDeptId", "value": "" },
    { "key": "fieldRoleId", "value": "" },
    { "key": "fieldRefId", "value": "" },
    { "key": "ruleId", "value": "" },
    { "key": "dependencyId", "value": "" },
    { "key": "submissionId", "value": "" },
    { "key": "resumeToken", "value": "" },
    { "key": "exportId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (obtain JWT)",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login/", "host": ["{{baseUrl}}"], "path": ["auth", "login", ""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.access) pm.collectionVariables.set('accessToken', body.access);",
                  "if (body.refresh) pm.collectionVariables.set('refreshToken', body.refresh);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh JWT",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/refresh/", "host": ["{{baseUrl}}"], "path": ["auth", "refresh", ""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.access) pm.collectionVariables.set('accessToken', body.access);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/", "host": ["{{baseUrl}}"], "path": ["users", ""] }
          }
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"analyst1\",\n  \"email\": \"analyst1@example.com\",\n  \"password\": \"ChangeMe123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/", "host": ["{{baseUrl}}"], "path": ["users", ""] }
          }
        },
        {
          "name": "Current user",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/me/", "host": ["{{baseUrl}}"], "path": ["users", "me", ""] }
          }
        },
        {
          "name": "User detail",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/:user_id/", "host": ["{{baseUrl}}"], "path": ["users", ":user_id", ""], "variable": [{ "key": "user_id", "value": "" }] }
          }
        }
      ]
    },
    {
      "name": "Surveys",
      "item": [
        {
          "name": "List surveys",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/surveys/", "host": ["{{baseUrl}}"], "path": ["surveys", ""] }
          }
        },
        {
          "name": "Create survey",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Job Application\",\n  \"description\": \"Demo survey for end-to-end walkthrough\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/surveys/", "host": ["{{baseUrl}}"], "path": ["surveys", ""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) pm.collectionVariables.set('surveyId', body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get survey",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", ""] }
          }
        },
        {
          "name": "Update survey",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Job Application (edited)\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", ""] }
          }
        },
        {
          "name": "Delete survey (archives)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", ""] }
          }
        },
        {
          "name": "Publish survey",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/publish/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "publish", ""] }
          }
        },
        {
          "name": "Archive survey",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/archive/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "archive", ""] }
          }
        },
        {
          "name": "Duplicate survey",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/surveys/{{surveyId}}/duplicate/", "host": ["{{baseUrl}}"], "path": ["surveys", "{{surveyId}}", "duplicate", ""] }
          }
        }
      ]
    },
